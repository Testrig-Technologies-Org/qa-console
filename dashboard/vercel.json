{
    "version": 2,
    "framework": "nextjs",
    "buildCommand": "npm run build",
    "installCommand": "npm install --legacy-peer-deps",
    "crons": [
        {
            "path": "/api/cron/cleanup-videos",
            "schedule": "0 3 * * *"
        },
        {
            "path": "/api/cron/embed-failures",
            "schedule": "*/30 * * * *"
        }
    ]
}