# Copy to .env and fill in to enable live reporting to the QA Console dashboard.
# All three must be set together or reporting is skipped for the run.

QA_CONSOLE_URL=https://your-qa-console-deployment.example.com
QA_CONSOLE_API_KEY=
QA_CONSOLE_PROJECT_ID=

# Optional. Groups multiple Playwright processes (e.g. sharded CI jobs) into a single build on
# the dashboard. Paste the key from the dashboard's Create_Build action for a project, or set
# your own stable per-run ID (e.g. $GITHUB_RUN_ID). Leave unset for one build per process.
QA_CONSOLE_SESSION_ID=
